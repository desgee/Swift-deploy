# GENERATED BY swiftdeploy — DO NOT EDIT MANUALLY

services:

  app:
    image: {{SERVICE_IMAGE}}
    container_name: swiftdeploy-app
    restart: {{RESTART_POLICY}}
    environment:
      MODE: "{{MODE}}"
      APP_VERSION: "{{APP_VERSION}}"
      APP_PORT: "{{SERVICE_PORT}}"
    networks:
      - {{NETWORK_NAME}}
    volumes:
      - {{LOGS_VOLUME}}:/var/log/app
    expose:
      - "{{SERVICE_PORT}}"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:{{SERVICE_PORT}}/healthz')\" || exit 1"]
      interval: 10s
      timeout: 5s
      start_period: 15s
      retries: 3

  nginx:
    image: {{NGINX_IMAGE}}
    container_name: swiftdeploy-nginx
    restart: {{RESTART_POLICY}}
    ports:
      - "{{NGINX_PORT}}:{{NGINX_PORT}}"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - {{NETWORK_NAME}}
    depends_on:
      app:
        condition: service_healthy

networks:
  {{NETWORK_NAME}}:
    driver: {{NETWORK_DRIVER}}

volumes:
  {{LOGS_VOLUME}}: